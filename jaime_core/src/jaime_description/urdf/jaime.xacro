    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="0.219497 -0.0 -0.695365" rpy="0 0 0"/>
    <geometry>
      <mesh filename="file://$(find jaime_description)/meshes/l1_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

