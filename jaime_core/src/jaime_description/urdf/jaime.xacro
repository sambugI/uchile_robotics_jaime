  <inertial>
    <origin xyz="0.09822806072614722 -0.02000000000000024 -0.00042655759258147796" rpy="0 0 0"/>
    <mass value="1.5878361136644155"/>
    <inertia ixx="0.000907" iyy="0.005126" izz="0.005257" ixy="-0.0" iyz="-0.0" ixz="0.000788"/>
