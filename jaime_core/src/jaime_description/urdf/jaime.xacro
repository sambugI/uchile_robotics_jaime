  <inertial>
    <origin xyz="0.0591163741924281 -0.019999466003310276 0.07299545187488221" rpy="0 0 0"/>
    <mass value="2.26906754439546"/>
    <inertia ixx="0.004039" iyy="0.007589" izz="0.004999" ixy="-0.0" iyz="-0.0" ixz="-0.003125"/>
