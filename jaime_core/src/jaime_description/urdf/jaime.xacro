<!-- <link name="world">
</link>

<link name="odom"/> -->
<!-- ver porque estan los dos de nuevo-->

<!-- inicio joints -->
<!-- se conecto kobuki a base_link y todo lo demas se conecto a kobuki despues -->

<!-- <joint name="world_to_odom" type="fixed">
  <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
  <parent link="world"/>
  <child link="odom"/>
</joint>


<joint name="odom_to_base_link" type="floating"> 
  <origin xyz= "0.0 0.0 0.0" rpy="0 0 0"/>
  <parent link="odom"/>
  <child link="base_link"/>
</joint> -->

<joint name="kobuki_base_joint" type="fixed">
  <origin xyz="0 0 -0.1" rpy="0 0 0" />
  <parent link="base_link"/>
  <child link="kobuki_base_link" />
</joint>

<joint name="l1_to_base_link" type="fixed">
  <origin xyz="-0.219497 0.0 0.695365" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="l1_1"/>
</joint>

<joint name="l2_to_l1" type="fixed">
  <origin xyz="0.025006 0.025 -0.043297" rpy="0 0.1 0"/>
  <parent link="l1_1"/>
  <child link="l2_1"/>
</joint>

<joint name="l3_to_l2" type="revolute">
  <origin xyz="-0.057619 -0.005 0.187133" rpy="0 -0.2 0"/>
  <parent link="l2_1"/>
  <child link="l3_1"/>
  <axis xyz="0.0 1.0 0.0"/>
  <limit upper="1.0" lower="-0.5" effort="100" velocity="100"/>
</joint>

<joint name="l4_to_l3" type="revolute">
  <origin xyz="-0.01409 0.0 0.097669" rpy="0 -0.5 0"/>
  <parent link="l3_1"/>
  <child link="l4_1"/>
  <axis xyz="0.0 1.0 -0.0"/>
  <limit upper="1.0" lower="-0.5" effort="100" velocity="100"/>
</joint>

<joint name="l5_to_l4" type="revolute">
  <origin xyz="0.150819 0.0 0.143079" rpy="0 -0.2 0"/>
  <parent link="l4_1"/>
  <child link="l5_1"/>
  <axis xyz="-0.0 1.0 -0.0"/>
  <limit upper="1.0" lower="-0.5" effort="100" velocity="100"/>
</joint>

<joint name="l6_to_l5" type="revolute">
  <origin xyz="0.091745 0.0 0.03634" rpy="0 -0.2 0"/>
  <parent link="l5_1"/>
  <child link="l6_1"/>
  <axis xyz="0.0 1.0 0.0"/>
  <limit upper="1.0" lower="-0.5" effort="100" velocity="100"/>
</joint>

<joint name="l7_to_l6" type="revolute">
  <origin xyz="0.200331 0.0 -0.02931" rpy="0 1   0"/>
  <parent link="l6_1"/>
  <child link="l7_1"/>
  <axis xyz="0.0 1.0 -0.0"/>
  <limit upper="2.1" lower="-2.1" effort="100" velocity="100"/>
</joint>


<!-- tcp tablet -->

<link name="tcp_tablet">

  <visual>
    <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
    <geometry>
      <sphere radius="0.001"/>
    </geometry>
  </visual>
  <collision>
    <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
    <geometry>
      <sphere radius="0.001"/>
    </geometry>
  </collision>
</link>

<!-- tcp camara (TODO ajustar a pose real)-->

<link name="tcp_front_camera">
  <visual>
    <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
    <geometry>
      <sphere radius="0.001"/>
    </geometry>
  </visual>
  <collision>
    <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
    <geometry>
      <sphere radius="0.001"/>
    </geometry>
  </collision>
  
</link>

<!-- joint l7_to_l6 hacia tcp tablet -->
<!-- ajustar desplazamiento en x real con cad -->

<joint name="tablet_effector" type="fixed">
  <parent link="l7_1"/>
  <child link="tcp_tablet"/>
  <origin xyz="0.055 0.0 0.0" rpy="0.0 0.0 0.0"/>
</joint>


<!-- joint de tcp tablet a tcp camera -->
<!-- este se debe ajustar luego a la pose final de la camera -->
<joint name="front_camera_effector" type="fixed">
  <parent link="tcp_tablet"/>
  <child link="tcp_front_camera"/>
  <origin xyz="0.0 0.0 0.08" rpy="0.0 0.0 0.0"/>
</joint>


<link name="base_footprint"/>

<joint name="base_footprint_joint" type="fixed">
  <parent link="base_link"/>
  <child link="base_footprint"/>
  <origin xyz="0 0 0" rpy="0 0 0"/>
</joint>

<link name="laser"/>

<joint name="laser_joint" type="fixed">
  <parent link="base_link"/>
  <child link="laser"/>
  <origin xyz="0 0 0" rpy="0 0 ${-pi}"/>
</joint>

</robot>
