<?xml version="1.0" ?>
<robot name="jaime" xmlns:xacro="http://www.ros.org/wiki/xacro">

<xacro:include filename="$(find jaime_description)/urdf/materials.xacro"/>
<xacro:include filename="$(find jaime_description)/urdf/ros2_control.xacro"/>
<xacro:include filename="$(find jaime_description)/urdf/kobuki_urdf.xacro"/>

<xacro:kobuki namespace="kobuki_"/>

<link name="base_link">
  <inertial>
    <origin xyz="-0.017499522969446787 -1.0526493480826139e-16 0.17440208425323425" rpy="0 0 0"/>
    <mass value="13.564884492489444"/>
    <inertia ixx="0.603443" iyy="0.661344" izz="0.113873" ixy="0.0" iyz="-0.0" ixz="0.136948"/>
  </inertial>
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="file://$(find jaime_description)/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="file://$(find jaime_description)/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

